# MongoDB
MONGODB_URI=your_mongodb_uri_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Payment Webhook
PAYMENT_WEBHOOK_KEY=your_webhook_key_here

# Site URL
NEXT_PUBLIC_SITE_URL=https://www.kmarket.mn

# NextAuth
NEXTAUTH_URL=https://www.kmarket.mn
NEXTAUTH_SECRET=your_nextauth_secret_here

# Coming Soon Mode - ENABLED for production (show coming soon page on domain)
NEXT_PUBLIC_COMING_SOON=true

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
